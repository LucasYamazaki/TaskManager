@model IEnumerable<TaskManager.Models.TaskItem>

<h2 class="mb-4">Lista de Tarefas</h2>

<a href="/TaskItems/Create" class="btn btn-primary mb-3">+ Nova Tarefa</a>

<div class="mb-3">
    <a href="/TaskItems" class="btn btn-secondary btn-sm">Todas</a>
    <a href="/TaskItems?filter=pendentes" class="btn btn-warning btn-sm">Pendentes</a>
    <a href="/TaskItems?filter=concluidas" class="btn btn-success btn-sm">Concluídas</a>
</div>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Descrição</th>
            <th>Status</th>
            <th>Ações</th>
            <th>Criada em</th>
            <th>Concluída em</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <strong>@item.Title</strong><br />
                    <small class="text-muted">@item.Description</small>
                </td>

                <td>
                    @if (item.IsCompleted)
                    {
                        <span class="badge bg-success">✔ Concluída</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">⏳ Pendente</span>
                    }
                </td>

                <td>
                    <a href="/TaskItems/Edit/@item.Id" class="btn btn-sm btn-primary">Editar</a>
                    <a href="/TaskItems/Delete/@item.Id" class="btn btn-sm btn-danger">Excluir</a>

                    @if (!item.IsCompleted)
                    {
                        <a href="/TaskItems/Complete/@item.Id" class="btn btn-sm btn-success">Concluir</a>
                    }
                    else
                    {
                        <a href="/TaskItems/Reopen/@item.Id" class="btn btn-sm btn-warning">Reabrir</a>
                    }
                </td>
                <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>

                <td>
                    @(item.CompletedAt.HasValue
                        ? item.CompletedAt.Value.ToString("dd/MM/yyyy HH:mm")
                        : "-")
                </td>
            </tr>
        }
    </tbody>
</table>